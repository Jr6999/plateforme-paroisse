# ═══════════════════════════════════════════════════════
#  Plateforme Paroisse Cathédrale — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════

# ── Général ─────────────────────────────────────────────
NODE_ENV=development

# ── API ──────────────────────────────────────────────────
# Koyeb injecte PORT automatiquement en production
PORT=4000
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# ── Base de données PostgreSQL ───────────────────────────
# Production : utiliser Koyeb Postgres ou Neon/Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parish_platform?schema=public

# ── Authentification JWT ─────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-me-cookie-secret-min-32-characters

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Sécurité ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Cloudinary (upload médias) ───────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Paroisse Cathedrale <noreply@paroisse.local>"

# ── Web (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
