# ═══════════════════════════════════════════════════════════════════════
#  Cathédrale Saint Sauveur de Natitingou — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs réelles
#  NE JAMAIS committer le fichier .env
# ═══════════════════════════════════════════════════════════════════════

# ── Général ─────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Serveur API ──────────────────────────────────────────────────────────
# Render / Koyeb / Railway injectent PORT automatiquement
PORT=4000
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# ── Base de données PostgreSQL ───────────────────────────────────────────
# Production : Neon, Supabase, Koyeb Postgres, Railway Postgres
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parish_platform?schema=public

# ── Authentification JWT ─────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-me-cookie-secret-minimum-32-characters

# ── CORS ─────────────────────────────────────────────────────────────────
# En production : URL exacte du frontend (sans trailing slash)
CORS_ORIGINS=http://localhost:3000

# ── Sécurité ─────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Cloudinary (upload médias — requis en production) ────────────────────
# Créer un compte sur https://cloudinary.com (plan gratuit disponible)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Alternative : URL unique (format cloudinary://api_key:api_secret@cloud_name)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Email SMTP ───────────────────────────────────────────────────────────
# Gmail : SMTP_HOST=smtp.gmail.com, PORT=587, activer "App Password"
# Brevo / Mailgun / Resend recommandés pour la production
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Cathédrale Saint Sauveur <noreply@cathedrale-natitingou.org>"

# ── Frontend Next.js ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
