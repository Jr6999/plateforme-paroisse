# ═══════════════════════════════════════════════════════════════════════════════
#  Plateforme Paroissiale Cathédrale — Variables d'environnement
#  Cathédrale Saint Sauveur de Natitingou, Bénin
#
#  ⚠  Copier ce fichier en .env et remplir TOUTES les valeurs obligatoires
#  ⚠  Ne JAMAIS committer le fichier .env dans Git
#
#  Générer des secrets sécurisés : openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environnement ───────────────────────────────────────────────────────────────
# Valeurs : development | test | production
NODE_ENV=development

# ── Serveur ─────────────────────────────────────────────────────────────────────
# PORT est injecté automatiquement par Render / Koyeb / Railway
# Ne pas modifier en production — laisser la plateforme gérer
PORT=4000
API_PORT=4000

# URLs publiques du service (utilisées dans Swagger, CORS, emails)
# En production : utiliser les URLs Render/Koyeb réelles
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# ── Base de données PostgreSQL ───────────────────────────────────────────────────
# OBLIGATOIRE — Le serveur ne démarrera pas sans cette variable
# Format  : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Render  : fourni automatiquement via "Connect Database"
# Neon    : https://neon.tech (plan gratuit disponible)
# Supabase: https://supabase.com (plan gratuit disponible)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parish_platform?schema=public

# ── Authentification JWT ─────────────────────────────────────────────────────────
# OBLIGATOIRES — Le serveur ne démarrera pas sans ces variables
# Minimum 32 caractères — Générer : openssl rand -hex 32
JWT_ACCESS_SECRET=REMPLACER_PAR_UNE_VALEUR_SECRETE_DE_32_CHARS_MINIMUM
JWT_REFRESH_SECRET=REMPLACER_PAR_UNE_AUTRE_VALEUR_SECRETE_32_CHARS_MIN

# Durée des tokens (formats valides : 15m, 1h, 7d, 30d)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Secret pour les cookies signés (optionnel mais recommandé, min 16 chars)
COOKIE_SECRET=REMPLACER_PAR_SECRET_COOKIE_MIN_16_CHARS

# ── CORS ─────────────────────────────────────────────────────────────────────────
# URL du frontend autorisé (sans slash final)
# Plusieurs origines séparées par des virgules : https://app.com,https://www.app.com
CORS_ORIGINS=http://localhost:3000

# ── Sécurité ─────────────────────────────────────────────────────────────────────
# Nombre de rounds bcrypt (10-14 recommandé, 12 par défaut)
BCRYPT_ROUNDS=12
# Fenêtre rate limiting en ms (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Nombre max de requêtes par fenêtre
RATE_LIMIT_MAX=120

# ── Cloudinary (upload médias) ───────────────────────────────────────────────────
# Requis pour l'upload de photos et documents en production
# Créer un compte gratuit : https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email SMTP ───────────────────────────────────────────────────────────────────
# Requis pour les emails de notification et de récupération de mot de passe
# Options recommandées :
#   Gmail   : SMTP_HOST=smtp.gmail.com, PORT=587 (activer "App Password")
#   Brevo   : SMTP_HOST=smtp-relay.brevo.com, PORT=587
#   Resend  : API key uniquement
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Cathédrale Saint Sauveur <noreply@cathedrale-natitingou.bj>"

# ── Frontend Next.js ─────────────────────────────────────────────────────────────
# Ces variables sont embarquées dans le bundle JavaScript au moment du build
# Elles doivent correspondre aux URLs réelles de production
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
